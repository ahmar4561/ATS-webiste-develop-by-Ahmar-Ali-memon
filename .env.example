# Copy this file to .env.local for local development.
# On Vercel, POSTGRES_URL is added automatically once you connect a
# Postgres database (Storage tab -> Create Database -> Postgres).
# You do NOT need to set it manually on Vercel.

POSTGRES_URL="postgres://user:password@host:5432/dbname"

# Admin panel password (used at /admin). Set this in Vercel's
# Project Settings -> Environment Variables before going live.
ADMIN_PASSWORD="change-this-password"
